{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure bexpeng/vscode development environment",
      "detail": "Symlinks the bexpeng/ package into Blender's addons directory and writes .vscode/settings.json with path mappings.",
      "type": "shell",
      "command": "blender",
      "args": [
        "--background",
        "--python",
        "${workspaceFolder}/scripts/dev_environment_vscode_config.py"
      ],
      "problemMatcher": []
    },
    {
      "label": "Launch Blender interactively",
      "detail": "Start Blender GUI with debugpy listening on port 5678. Then attach with 'Interactive+debugger' (F5).",
      "type": "shell",
      "command": "blender",
      "args": [
        "--python",
        ".vscode/debugpy_port.py",
        "--",
        "--log_level=DEBUG",
        "--interactive"
      ],
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Run Blender+testing",
      "detail": "Run the bexpeng test suite headlessly via Blender's Python. Opens debugpy on port 5678 then runs pytest.",
      "type": "shell",
      "command": "blender",
      "args": [
        "--background",
        "--python",
        ".vscode/debugpy_port.py",
        "--python",
        "scripts/run_tests.py"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "python",
        "source": "python",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^ *File \"([/\\w.]+)\", line (\\d+), in (\\w+)\n *(.*)\n(\\w+: .*)$",
          "file": 1,
          "line": 2,
          "code": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Blender.*$",
          "endsPattern": "^Blender quit$"
        }
      }
    }
  ]
}
